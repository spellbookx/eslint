{
  "name": "@spellbookx/eslint-config",
  "version": "1.0.0",
  "description": "A ready to use eslint config for a curated list of languages and file types.",
  "license": "MIT",
  "author": "Davide Di Criscito <davide.dicriscito@gmail.com>",
  "keywords": [
    "eslint",
    "eslint-config",
    "eslint-plugin",
    "eslint-plugin-import",
    "spellbookx",
    "javascript",
    "typescript",
    "markdown",
    "json",
    "jsonc",
    "json5",
    "stylistic"
  ],
  "type": "module",
  "main": "./lib/index.js",
  "exports": {
    ".": "./lib/index.js",
    "./config/global.js": "./lib/global.js",
    "./config/eslint-config.js": "./lib/eslint-config.js",
    "./config-javascript.js": "./lib/javascript.js",
    "./config-typescript.js": "./lib/typescript.js",
    "./config-json.js": "./lib/json.js",
    "./config-markdown.js": "./lib/markdown.js",
    "./config-stylistic.js": "./lib/stylistic.js",
    "./package.json": "./package.json"
  },
  "files": [
    "LICENSE"
  ],
  "scripts": {
    "build:types": "pnpm exec tsc --build --verbose"
  },
  "packageManager": "pnpm@10.12.1",
  "dependencies": {
    "@eslint/js": "^9.29.0",
    "@eslint/json": "^0.12.0",
    "@eslint/markdown": "^6.5.0",
    "@stylistic/eslint-plugin": "^4.4.1",
    "eslint-import-resolver-typescript": "^4.4.3",
    "eslint-plugin-import": "^2.31.0",
    "typescript-eslint": "^8.34.1"
  },
  "devDependencies": {
    "eslint": "^9.29.0",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "eslint": "^9.29.0",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
